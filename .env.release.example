# Copy to .env.release and set real values.

RELEASE_SSH_HOST=piclock.local
RELEASE_SSH_USER=piclock
RELEASE_REMOTE_DIR=/home/piclock/gw2_tools
RELEASE_PM2_APP=gw2-tools-bot

# Auth mode: key or onepassword
RELEASE_SSH_AUTH_MODE=onepassword

# Used when RELEASE_SSH_AUTH_MODE=key
RELEASE_SSH_KEY_PATH=/home/your-user/.ssh/id_ed25519

# Used when RELEASE_SSH_AUTH_MODE=onepassword and SSH_AUTH_SOCK is not already set
RELEASE_1PASSWORD_AGENT_SOCK=/home/your-user/.1password/agent.sock
